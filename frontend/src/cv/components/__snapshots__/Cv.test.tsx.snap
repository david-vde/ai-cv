// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Cv - rendering > should render an embed tag with the correct src from contact.cv_url config 1`] = `
<div>
  <div
    class="cv"
  >
    <div
      class="download"
    >
      <a
        class="link"
        download=""
        href="/CV-DAVID.pdf"
        rel="noopener noreferrer"
        target="_blank"
      >
        ⬇ 
        cv.downloadMyPdfCV - translated
      </a>
    </div>
    <embed
      height="100%"
      src="/CV-DAVID.pdf#toolbar=0&navpanes=0"
      type="application/pdf"
      width="80%"
    />
  </div>
</div>
`;

